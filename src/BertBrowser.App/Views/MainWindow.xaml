<Window x:Class="BertBrowser.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BertBrowser.App.ViewModels"
        Title="BertBrowser" Width="1200" Height="750"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=vm:ShellViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Window.InputBindings>
        <KeyBinding Key="Back" Command="{Binding BackCommand}"/>
        <KeyBinding Key="Left" Modifiers="Alt" Command="{Binding BackCommand}"/>
        <KeyBinding Key="Right" Modifiers="Alt" Command="{Binding ForwardCommand}"/>
        <KeyBinding Key="Up" Modifiers="Alt" Command="{Binding UpCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- Header: toolbar, tag filter, error banner -->
        <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <StackPanel>
            <!-- Tag filter panel -->
            <Expander Header="Tag filter" IsExpanded="False" Padding="6,2" Margin="6,4,6,0">
                <StackPanel>
                    <WrapPanel Margin="0,4">
                        <ItemsControl ItemsSource="{Binding TagFilter.Tags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="0,2,12,2">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="{Binding Tag.Color, Converter={StaticResource TagColor}}"
                                                    Width="10" Height="10" CornerRadius="5" Margin="0,0,4,0"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Tag.Name}"/>
                                            <TextBlock Text="{Binding Count, StringFormat=' ({0})'}" Foreground="Gray"/>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,6">
                        <TextBlock Text="Match:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <RadioButton Content="Any selected tag" IsChecked="{Binding TagFilter.MatchAll, Converter={StaticResource InverseBool}, Mode=TwoWay}"
                                     Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <RadioButton Content="All selected tags" IsChecked="{Binding TagFilter.MatchAll, Mode=TwoWay}"
                                     VerticalAlignment="Center"/>
                        <Button Content="Clear" Command="{Binding TagFilter.ClearCommand}" Margin="16,0,0,0" Padding="8,2"/>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <DockPanel Margin="6,4">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Style="{StaticResource ToolbarButton}" Content="◀" ToolTip="Back (Alt+Left)"
                            Command="{Binding BackCommand}"/>
                    <Button Style="{StaticResource ToolbarButton}" Content="▶" ToolTip="Forward (Alt+Right)"
                            Command="{Binding ForwardCommand}"/>
                    <Button Style="{StaticResource ToolbarButton}" Content="▲" ToolTip="Up (Alt+Up)"
                            Command="{Binding UpCommand}"/>
                    <Button Style="{StaticResource ToolbarButton}" Content="⟳" ToolTip="Refresh (F5)"
                            Command="{Binding RefreshCommand}"/>
                    <Separator Margin="4,2"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Style="{StaticResource ToolbarButton}" Content="Σ Sizes here"
                            ToolTip="Compute content sizes of all folders in this directory"
                            Command="{Binding ComputeSizesHereCommand}"/>
                    <Button Style="{StaticResource ToolbarButton}" Content="✕ Cancel scan"
                            Command="{Binding CancelScansCommand}"/>
                    <Button Style="{StaticResource ToolbarButton}" Content="🏷 Manage tags"
                            Click="ManageTags_Click"/>
                </StackPanel>

                <!-- Breadcrumb / editable path -->
                <Grid Margin="6,0">
                    <ItemsControl x:Name="Breadcrumb" ItemsSource="{Binding BreadcrumbSegments}"
                                  VerticalAlignment="Center"
                                  MouseLeftButtonUp="Breadcrumb_EmptyClick" Background="Transparent">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource BreadcrumbButton}" Content="{Binding Name}"
                                            Click="BreadcrumbSegment_Click" Tag="{Binding FullPath}"/>
                                    <TextBlock Text="›" VerticalAlignment="Center" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBox x:Name="PathBox" Visibility="Collapsed" VerticalAlignment="Center"
                             KeyDown="PathBox_KeyDown" LostFocus="PathBox_LostFocus"/>
                </Grid>
            </DockPanel>

            <!-- Error banner -->
            <Border Background="#FFF4E5" Padding="8,4"
                    Visibility="{Binding FileList.ErrorMessage, Converter={StaticResource NullToCollapsed}}">
                <TextBlock Text="{Binding FileList.ErrorMessage}" Foreground="#8A6D3B" TextWrapping="Wrap"/>
            </Border>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="150"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Folder tree -->
            <TreeView Grid.Column="0" ItemsSource="{Binding Tree.Roots}" BorderThickness="0"
                      Background="White" Padding="0,4"
                      ItemContainerStyle="{StaticResource FolderTreeItemStyle}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      VirtualizingPanel.IsVirtualizing="False">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <DockPanel Background="Transparent">
                            <Image DockPanel.Dock="Left" Source="{Binding Icon}"
                                   Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding FullPath}"/>
                        </DockPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#EEE"/>

            <!-- File list -->
            <ListView x:Name="FileListView" Grid.Column="2"
                          ItemsSource="{Binding FileList.Items}"
                          BorderThickness="0"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.IsDeferredScrollingEnabled="False"
                          GridViewColumnHeader.Click="FileList_HeaderClick"
                          MouseDoubleClick="FileList_DoubleClick">
                    <ListView.ItemContainerStyle>
                        <StaticResource ResourceKey="FileRowStyle"/>
                    </ListView.ItemContainerStyle>
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Open" Click="ContextOpen_Click"/>
                            <Separator/>
                            <MenuItem Header="Tags…" Click="ContextTags_Click"/>
                            <MenuItem Header="Compute size" Click="ContextComputeSize_Click"/>
                            <Separator/>
                            <MenuItem Header="Remove missing entry" Click="ContextRemoveMissing_Click"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="320" x:Name="NameColumn">
                                <GridViewColumnHeader Content="Name" Tag="Name"/>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="220" x:Name="RelPathColumn">
                                <GridViewColumnHeader Content="Relative path" Tag="RelativePath"/>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RelativePath}" Foreground="Gray"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="110">
                                <GridViewColumnHeader Content="Size" Tag="Size"/>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <TextBlock Text="{Binding SizeDisplay}" HorizontalAlignment="Right"
                                                       ToolTip="{Binding SizeTooltip}"
                                                       Visibility="{Binding IsSizeComputing, Converter={StaticResource InverseBoolToVisibility}}"/>
                                            <ProgressBar IsIndeterminate="True" Height="10" Width="70"
                                                         Visibility="{Binding IsSizeComputing, Converter={StaticResource BoolToVisibility}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="120">
                                <GridViewColumnHeader Content="Type" Tag="Type"/>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TypeName}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="140">
                                <GridViewColumnHeader Content="Modified" Tag="Modified"/>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ModifiedDisplay}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="200">
                                <GridViewColumnHeader Content="Tags" Tag="Tags"/>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding Tags}" ItemTemplate="{StaticResource TagChipTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
            </ListView>
        </Grid>
    </DockPanel>
</Window>
