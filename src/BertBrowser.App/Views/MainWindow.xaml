<Window x:Class="BertBrowser.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BertBrowser.App.ViewModels"
        Title="BertBrowser" Width="1200" Height="750"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=vm:ShellViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Window.InputBindings>
        <KeyBinding Key="Back" Command="{Binding BackCommand}"/>
        <KeyBinding Key="Left" Modifiers="Alt" Command="{Binding BackCommand}"/>
        <KeyBinding Key="Right" Modifiers="Alt" Command="{Binding ForwardCommand}"/>
        <KeyBinding Key="Up" Modifiers="Alt" Command="{Binding UpCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- Thumbnail (tile) view: a wrap of square previews with the name beneath. The tile
             and image size track FileList.ThumbnailSize so the footer slider resizes them live. -->
        <ItemsPanelTemplate x:Key="ThumbPanel">
            <WrapPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>

        <DataTemplate x:Key="ThumbTileTemplate">
            <StackPanel Margin="6,6,6,2"
                        Width="{Binding DataContext.FileList.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListView}}">
                <Image Source="{Binding Thumbnail}" Opacity="{Binding IconOpacity}"
                       Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Width="{Binding DataContext.FileList.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListView}}"
                       Height="{Binding DataContext.FileList.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                <TextBlock Text="{Binding Name}" TextWrapping="Wrap" TextAlignment="Center"
                           Margin="0,4,0,0" MaxHeight="32" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </DataTemplate>

        <Style x:Key="ThumbItemStyle" TargetType="ListViewItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Margin="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource RowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource RowSelectedBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource RowSelectedHoverBrush}"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource RowSelectedInactiveBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header: toolbar, tag filter, error banner -->
        <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <StackPanel>
            <!-- Tag filter panel -->
            <Expander Header="Tag filter" IsExpanded="False" Padding="6,2" Margin="6,4,6,0">
                <StackPanel>
                    <WrapPanel Margin="0,4">
                        <ItemsControl ItemsSource="{Binding TagFilter.Tags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="0,2,12,2">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="{Binding Tag.Color, Converter={StaticResource TagColor}}"
                                                    Width="10" Height="10" CornerRadius="5" Margin="0,0,4,0"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Tag.Name}"/>
                                            <TextBlock Text="{Binding Count, StringFormat=' ({0})'}" Foreground="Gray"/>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,6">
                        <TextBlock Text="Match:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <RadioButton Content="Any selected tag" IsChecked="{Binding TagFilter.MatchAll, Converter={StaticResource InverseBool}, Mode=TwoWay}"
                                     Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <RadioButton Content="All selected tags" IsChecked="{Binding TagFilter.MatchAll, Mode=TwoWay}"
                                     VerticalAlignment="Center"/>
                        <Button Content="Clear" Command="{Binding TagFilter.ClearCommand}" Margin="16,0,0,0" Padding="8,2"/>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <DockPanel Margin="6,4">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Back (Alt+Left)"
                            Command="{Binding BackCommand}">
                        <TextBlock Style="{StaticResource ToolbarIcon}" Text="&#xE72B;"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Forward (Alt+Right)"
                            Command="{Binding ForwardCommand}">
                        <TextBlock Style="{StaticResource ToolbarIcon}" Text="&#xE72A;"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Up (Alt+Up)"
                            Command="{Binding UpCommand}">
                        <TextBlock Style="{StaticResource ToolbarIcon}" Text="&#xE74A;"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Refresh (F5)"
                            Command="{Binding RefreshCommand}">
                        <TextBlock Style="{StaticResource ToolbarIcon}" Text="&#xE72C;"/>
                    </Button>
                    <Separator Margin="4,2"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Style="{StaticResource ToolbarButton}"
                            ToolTip="Compute content sizes of all folders in this directory"
                            Command="{Binding ComputeSizesHereCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIcon}" Text="&#xE1D0;" Margin="0,0,6,0"/>
                            <TextBlock Text="Sizes here" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding CancelScansCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIcon}" Text="&#xE711;" Margin="0,0,6,0"/>
                            <TextBlock Text="Cancel scan" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Click="ManageTags_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIcon}" Text="&#xE8EC;" Margin="0,0,6,0"/>
                            <TextBlock Text="Manage tags" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Separator Margin="4,2"/>
                    <Button Style="{StaticResource ToolbarButton}"
                            ToolTip="Scan progress" Click="ScanProgress_Click">
                        <TextBlock Style="{StaticResource ToolbarIcon}" Text="&#xE9D9;"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}"
                            ToolTip="Settings — custom context menu commands"
                            Click="Settings_Click">
                        <TextBlock Style="{StaticResource ToolbarIcon}" Text="&#xE713;"/>
                    </Button>
                </StackPanel>

                <!-- Breadcrumb / editable path + search -->
                <Grid Margin="6,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- Address bar: same rounded field chrome as the search box. -->
                    <Border Style="{StaticResource FieldBorder}" Padding="6,0">
                        <Grid>
                            <ItemsControl x:Name="Breadcrumb" ItemsSource="{Binding BreadcrumbSegments}"
                                          VerticalAlignment="Center"
                                          MouseLeftButtonUp="Breadcrumb_EmptyClick" Background="Transparent">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource BreadcrumbButton}" Content="{Binding Name}"
                                                    Click="BreadcrumbSegment_Click" Tag="{Binding FullPath}"/>
                                            <TextBlock Text="›" VerticalAlignment="Center" Foreground="Gray"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBox x:Name="PathBox" Visibility="Collapsed" VerticalAlignment="Center"
                                     BorderThickness="0" Background="Transparent"
                                     KeyDown="PathBox_KeyDown" LostFocus="PathBox_LostFocus"/>
                        </Grid>
                    </Border>

                    <!-- Local search that doesn't suck: files & folders under the current directory. -->
                    <Border Grid.Column="1" Style="{StaticResource FieldBorder}" Margin="8,0,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" FontFamily="{StaticResource SymbolFont}"
                                       Text="&#xE721;" FontSize="13" Margin="8,0,6,0"
                                       VerticalAlignment="Center" Foreground="#666"/>
                            <Button DockPanel.Dock="Right" ToolTip="Clear search (Esc)"
                                    Command="{Binding ClearSearchCommand}"
                                    Style="{StaticResource SearchClearButton}">
                                <TextBlock FontFamily="{StaticResource SymbolFont}" Text="&#xE711;" FontSize="12"/>
                            </Button>
                            <Grid>
                                <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center"
                                         AutomationProperties.Name="Search this folder"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="SearchBox_KeyDown"
                                         ToolTip="Search files and folders under this directory (Ctrl+F)"/>
                                <TextBlock Text="Search this folder" Foreground="Gray" Margin="4,0,0,0"
                                           VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </DockPanel>

            <!-- Activity indicator: search / directory load in progress (fixed height, no layout shift) -->
            <Grid Height="3" Margin="6,1,6,0">
                <ProgressBar IsIndeterminate="True" BorderThickness="0"
                             Visibility="{Binding FileList.IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>

            <!-- Error banner -->
            <Border Background="#FFF4E5" Padding="8,4"
                    Visibility="{Binding FileList.ErrorMessage, Converter={StaticResource NullToCollapsed}}">
                <TextBlock Text="{Binding FileList.ErrorMessage}" Foreground="#8A6D3B" TextWrapping="Wrap"/>
            </Border>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel HorizontalAlignment="Stretch" LastChildFill="False"/>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem DockPanel.Dock="Left">
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <!-- Thumbnail size: min = details list, dragging right grows thumbnails. -->
            <StatusBarItem DockPanel.Dock="Right">
                <StackPanel Orientation="Horizontal" ToolTip="Thumbnail size — drag left for the details list">
                    <TextBlock Style="{StaticResource ToolbarIcon}" FontSize="13" Text="&#xE8FD;"
                               Margin="0,0,6,0" Foreground="#666" VerticalAlignment="Center"/>
                    <Slider x:Name="ThumbSlider" Width="130" Minimum="0" Maximum="1"
                            VerticalAlignment="Center"
                            Value="{Binding FileList.ThumbnailScale, Mode=TwoWay}"
                            AutomationProperties.Name="Thumbnail size"/>
                </StackPanel>
            </StatusBarItem>
            <!-- Live scan progress; click to open the scan-progress dialog. -->
            <StatusBarItem DockPanel.Dock="Right"
                           Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}">
                <Button Style="{StaticResource BreadcrumbButton}" Click="ScanProgress_Click"
                        ToolTip="Show all scan progress">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource ToolbarIcon}" FontSize="13" Text="&#xE9D9;"
                                   Margin="0,0,6,0" Foreground="#1C86D1"/>
                        <TextBlock Text="{Binding ScanSummary}" VerticalAlignment="Center" Foreground="#1C86D1"/>
                    </StackPanel>
                </Button>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="150"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left sidebar: drives/devices (top, fills rest) + bookmarks (below, only as tall as needed) -->
            <Grid Grid.Column="0" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Bookmarks (below the drive list; sized to content) -->
                <DockPanel Grid.Row="1">
                    <Border DockPanel.Dock="Top" BorderBrush="#EEE" BorderThickness="0,1,0,0">
                        <TextBlock Text="BOOKMARKS" Style="{StaticResource SidebarHeader}"/>
                    </Border>
                    <TextBlock DockPanel.Dock="Top" Margin="10,0,10,8" Foreground="#AAA" FontSize="11"
                               TextWrapping="Wrap" Text="Right-click a file or folder to bookmark it."
                               Visibility="{Binding Bookmarks.HasBookmarks, Converter={StaticResource InverseBoolToVisibility}}"/>
                    <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding Bookmarks.HasBookmarks, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl ItemsSource="{Binding Bookmarks.Items}" Margin="0,0,0,6">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="BmRow" Background="Transparent" Padding="10,4"
                                            MouseLeftButtonUp="BookmarkRow_MouseUp" ToolTip="{Binding FullPath}">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Open" Click="BookmarkOpen_Click">
                                                    <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8E5;"/></MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="Remove bookmark" Click="BookmarkRemove_Click">
                                                    <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE74D;"/></MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <DockPanel>
                                            <Image DockPanel.Dock="Left" Source="{Binding Icon}"
                                                   Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="BmRow" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BmRow" Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>

                <!-- Drives & devices (fills the sidebar above the bookmarks) -->
                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Top" Text="DRIVES &amp; DEVICES" Style="{StaticResource SidebarHeader}"/>
            <TreeView x:Name="FolderTree" ItemsSource="{Binding Tree.Roots}" BorderThickness="0"
                      Background="White" Padding="0,2"
                      ItemContainerStyle="{StaticResource FolderTreeItemStyle}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      VirtualizingPanel.IsVirtualizing="False"
                      MouseDoubleClick="FolderTree_DoubleClick"
                      ContextMenuOpening="FolderTree_ContextMenuOpening">
                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open in Terminal" Click="TreeOpenTerminal_Click">
                            <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE756;"/></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Open in VS Code" Click="TreeOpenVSCode_Click">
                            <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE943;"/></MenuItem.Icon>
                        </MenuItem>
                        <Separator/>
                        <MenuItem x:Name="TreeBookmarkMenuItem" Header="Bookmark" Click="TreeBookmark_Click">
                            <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE734;"/></MenuItem.Icon>
                        </MenuItem>
                        <Separator x:Name="TreeCustomCommandsSeparator" Visibility="Collapsed"/>
                        <Separator/>
                        <MenuItem Header="Properties…" Click="TreeProperties_Click">
                            <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE946;"/></MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </TreeView.ContextMenu>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <DockPanel Background="Transparent">
                            <Image DockPanel.Dock="Left" Source="{Binding Icon}"
                                   Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding FullPath}"/>
                        </DockPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
                </DockPanel>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#EEE"/>

            <!-- File list -->
            <ListView x:Name="FileListView" Grid.Column="2"
                          ItemsSource="{Binding FileList.Items}"
                          BorderThickness="0"
                          IsTextSearchEnabled="False"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.IsDeferredScrollingEnabled="False"
                          GridViewColumnHeader.Click="FileList_HeaderClick"
                          MouseDoubleClick="FileList_DoubleClick"
                          SelectionChanged="FileList_SelectionChanged"
                          TextInput="FileList_TextInput"
                          ContextMenuOpening="FileList_ContextMenuOpening">
                    <ListView.ItemContainerStyle>
                        <StaticResource ResourceKey="FileRowStyle"/>
                    </ListView.ItemContainerStyle>
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Open" Click="ContextOpen_Click">
                                <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8E5;"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Open in Terminal" Click="ContextOpenTerminal_Click">
                                <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE756;"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Open in VS Code" Click="ContextOpenVSCode_Click">
                                <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE943;"/></MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem x:Name="CutMenuItem" Header="Cut" InputGestureText="Ctrl+X" Click="ContextCut_Click">
                                <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8C6;"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem x:Name="CopyMenuItem" Header="Copy" InputGestureText="Ctrl+C" Click="ContextCopy_Click">
                                <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8C8;"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem x:Name="PasteMenuItem" Header="Paste" InputGestureText="Ctrl+V" Click="ContextPaste_Click">
                                <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE77F;"/></MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="Tags…" Click="ContextTags_Click">
                                <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8EC;"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Compute size" Click="ContextComputeSize_Click">
                                <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE1D0;"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem x:Name="BookmarkMenuItem" Header="Bookmark" Click="ContextBookmark_Click">
                                <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE734;"/></MenuItem.Icon>
                            </MenuItem>
                            <Separator x:Name="CustomCommandsSeparator" Visibility="Collapsed"/>
                            <Separator/>
                            <MenuItem Header="Remove missing entry" Click="ContextRemoveMissing_Click">
                                <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE74D;"/></MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="Properties…" InputGestureText="Alt+Enter" Click="ContextProperties_Click">
                                <MenuItem.Icon><TextBlock Style="{StaticResource MenuIcon}" Text="&#xE946;"/></MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.View>
                        <GridView x:Name="DetailsView">
                            <GridViewColumn Width="320" x:Name="NameColumn">
                                <GridViewColumnHeader Content="Name" Tag="Name"/>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0"
                                                   Opacity="{Binding IconOpacity}"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="220" x:Name="RelPathColumn">
                                <GridViewColumnHeader Content="Relative path" Tag="RelativePath"/>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RelativePath}" Foreground="Gray"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="110">
                                <GridViewColumnHeader Content="Size" Tag="Size"/>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <TextBlock Text="{Binding SizeDisplay}" HorizontalAlignment="Right"
                                                       ToolTip="{Binding SizeTooltip}"
                                                       Visibility="{Binding IsSizeComputing, Converter={StaticResource InverseBoolToVisibility}}"/>
                                            <ProgressBar IsIndeterminate="True" Height="10" Width="70"
                                                         Visibility="{Binding IsSizeComputing, Converter={StaticResource BoolToVisibility}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="120">
                                <GridViewColumnHeader Content="Type" Tag="Type"/>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TypeName}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="140">
                                <GridViewColumnHeader Content="Modified" Tag="Modified"/>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ModifiedDisplay}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="200">
                                <GridViewColumnHeader Content="Tags" Tag="Tags"/>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding Tags}" ItemTemplate="{StaticResource TagChipTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
            </ListView>

            <!-- Inline empty state for searches with no hits -->
            <TextBlock Grid.Column="2" IsHitTestVisible="False"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="Gray"
                       Text="{Binding FileList.EmptyMessage}"
                       Visibility="{Binding FileList.EmptyMessage, Converter={StaticResource NullToCollapsed}}"/>
        </Grid>
    </DockPanel>
</Window>
