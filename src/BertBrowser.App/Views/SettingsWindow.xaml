<Window x:Class="BertBrowser.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="620" Height="440"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <DockPanel Margin="10">
        <TextBlock DockPanel.Dock="Top" Text="Custom context menu commands" FontWeight="SemiBold"/>
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="Gray" Margin="0,4,0,10"
                   Text="These commands appear in the right-click menu of the file list and folder tree. In Arguments, {path}, {name} and {dir} expand per item — quote tokens that may contain spaces, e.g. &quot;{path}&quot;. Blank arguments default to the quoted full path."/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Padding="16,4" Margin="0,0,6,0" IsDefault="True" Click="Save_Click"/>
            <Button Content="Cancel" Padding="16,4" IsCancel="True"/>
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Command list -->
            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="Add" Padding="12,3" Margin="0,0,6,0" Command="{Binding AddCommand}"/>
                    <Button Content="Remove" Padding="12,3" Command="{Binding RemoveCommand}"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding Commands}" SelectedItem="{Binding SelectedCommand, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Margin="2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Editor for the selected command -->
            <Grid Grid.Column="2" VerticalAlignment="Top">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedCommand}" Value="{x:Null}">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8"
                         VerticalContentAlignment="Center"
                         Text="{Binding SelectedCommand.Name, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Program:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,6,8"
                         VerticalContentAlignment="Center"
                         Text="{Binding SelectedCommand.Command, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Row="1" Grid.Column="2" Content="…" Width="28" Margin="0,0,0,8"
                        ToolTip="Browse for a program" Click="Browse_Click"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Arguments:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8"
                         VerticalContentAlignment="Center"
                         ToolTip="{}{path} = full path, {name} = file name, {dir} = parent directory"
                         Text="{Binding SelectedCommand.Arguments, UpdateSourceTrigger=PropertyChanged}"/>

                <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                    <CheckBox Content="Show for files" IsChecked="{Binding SelectedCommand.AppliesToFiles}"
                              Margin="0,0,16,0"/>
                    <CheckBox Content="Show for folders" IsChecked="{Binding SelectedCommand.AppliesToDirectories}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
