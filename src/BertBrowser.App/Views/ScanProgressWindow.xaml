<Window x:Class="BertBrowser.App.Views.ScanProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BertBrowser.App.ViewModels"
        Title="Scan progress" Width="560" Height="420"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        d:DataContext="{d:DesignInstance Type=vm:ShellViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="Active size scans" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel all" Padding="16,4" Margin="0,0,6,0"
                    Command="{Binding CancelScansCommand}"/>
            <Button Content="Close" Padding="16,4" IsCancel="True" IsDefault="True"/>
        </StackPanel>

        <!-- Empty state -->
        <TextBlock DockPanel.Dock="Top" Foreground="Gray" Margin="0,24,0,0"
                   HorizontalAlignment="Center" Text="No scans are running."
                   Visibility="{Binding IsScanning, Converter={StaticResource InverseBoolToVisibility}}"/>

        <ListBox ItemsSource="{Binding ActiveScans}" BorderBrush="#DDD" BorderThickness="1"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="Padding" Value="8,8"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding FolderName}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding FolderPath}" Foreground="Gray" FontSize="11"
                                       TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                            <TextBlock Foreground="#666" FontSize="11" Margin="0,3,0,0">
                                <Run Text="{Binding DirectoriesScanned, StringFormat=N0, Mode=OneWay}"/><Run Text=" folders · "/><Run Text="{Binding BytesDisplay, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding CurrentDirectory}" Foreground="#AAA" FontSize="11"
                                       TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                            <ProgressBar IsIndeterminate="True" Height="4" Margin="0,6,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                Padding="12,3" Content="Cancel"
                                Command="{Binding CancelCommand}"
                                IsEnabled="{Binding IsCancelling, Converter={StaticResource InverseBool}}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
