<Window x:Class="BertBrowser.App.Views.PropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Width="500" Height="640" MinWidth="400" MinHeight="440"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="PropName" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Margin" Value="0,3,12,3"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <!-- Read-only borderless TextBox so values stay selectable/copyable. -->
        <Style x:Key="PropValue" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Image Source="{Binding Icon}" Width="32" Height="32" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                       VerticalAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>

        <Border DockPanel.Dock="Top" Background="#FFF4E5" BorderBrush="#E6C079" BorderThickness="1"
                CornerRadius="3" Padding="8,6" Margin="0,0,0,8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}">
            <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"/>
        </Border>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Close" Width="80" IsCancel="True"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="General" Padding="8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Location:" Style="{StaticResource PropName}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FullPath, Mode=OneWay}" Style="{StaticResource PropValue}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Type:" Style="{StaticResource PropName}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TypeName, Mode=OneWay}" Style="{StaticResource PropValue}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Size:" Style="{StaticResource PropName}"
                                   Visibility="{Binding SizeDisplay, Converter={StaticResource NullToCollapsed}}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SizeDisplay, Mode=OneWay}" Style="{StaticResource PropValue}"
                                 Visibility="{Binding SizeDisplay, Converter={StaticResource NullToCollapsed}}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Created:" Style="{StaticResource PropName}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CreatedDisplay, Mode=OneWay}" Style="{StaticResource PropValue}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Modified:" Style="{StaticResource PropName}"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ModifiedDisplay, Mode=OneWay}" Style="{StaticResource PropValue}"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Accessed:" Style="{StaticResource PropName}"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding AccessedDisplay, Mode=OneWay}" Style="{StaticResource PropValue}"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Attributes:" Style="{StaticResource PropName}"/>
                        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,3"
                                    IsEnabled="{Binding IsMissing, Converter={StaticResource InverseBool}}">
                            <CheckBox Content="Read-only" IsChecked="{Binding IsReadOnly}" VerticalAlignment="Center"/>
                            <CheckBox Content="Hidden" IsChecked="{Binding IsHidden}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            <Button Content="Apply" Padding="12,2" Margin="16,0,0,0"
                                    Command="{Binding ApplyAttributesCommand}"
                                    ToolTip="Applies to this item only, not folder contents."/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Folder contents" Padding="8" Margin="0,0,0,8"
                          Visibility="{Binding IsDirectory, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Size:" Style="{StaticResource PropName}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource PropValue}"
                                 Text="{Binding FolderSizeDisplay, Mode=OneWay, TargetNullValue='Not yet calculated'}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Contains:" Style="{StaticResource PropName}"
                                   Visibility="{Binding FolderCountsDisplay, Converter={StaticResource NullToCollapsed}}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FolderCountsDisplay, Mode=OneWay}" Style="{StaticResource PropValue}"
                                 Visibility="{Binding FolderCountsDisplay, Converter={StaticResource NullToCollapsed}}"/>

                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SizeComputedDisplay, Mode=OneWay}"
                                 Style="{StaticResource PropValue}" Foreground="#666" FontSize="11"
                                 Visibility="{Binding SizeComputedDisplay, Converter={StaticResource NullToCollapsed}}"/>

                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Vertical" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Calculate" Padding="12,2" Command="{Binding CalculateSizeCommand}"/>
                                <Button Content="Cancel" Padding="12,2" Margin="8,0,0,0"
                                        Command="{Binding CancelCalculateCommand}"
                                        Visibility="{Binding IsCalculating, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Margin="0,6,0,0"
                                        Visibility="{Binding IsCalculating, Converter={StaticResource BoolToVisibility}}">
                                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding ScanProgressText}" Foreground="#666" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Tags" Padding="8" Margin="0,0,0,8"
                          Visibility="{Binding IsDirectory, Converter={StaticResource InverseBoolToVisibility}}">
                    <Grid>
                        <ItemsControl ItemsSource="{Binding Tags}" ItemTemplate="{StaticResource TagChipTemplate}"
                                      Visibility="{Binding HasTags, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <TextBlock Text="No tags" Foreground="#999"
                                   Visibility="{Binding HasTags, Converter={StaticResource InverseBoolToVisibility}}"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Details" Padding="8">
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True" Height="4" Margin="0,2,0,6"
                                     Visibility="{Binding IsLoadingDetails, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="No additional metadata" Foreground="#999"
                                   Visibility="{Binding ShowNoMetadata, Converter={StaticResource BoolToVisibility}}"/>
                        <ItemsControl ItemsSource="{Binding DetailProperties}" Grid.IsSharedSizeScope="True">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="90" SharedSizeGroup="DetailName"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource PropName}"/>
                                        <TextBox Grid.Column="1" Text="{Binding Value, Mode=OneWay}" Style="{StaticResource PropValue}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
